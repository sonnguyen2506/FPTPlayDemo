@{
    Layout = null;
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Panel | @ViewData["Title"]</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">

    <style>
        body {
            background: #f4f6f9;
            font-family: 'Segoe UI', Tahoma;
        }

        /* ===== SIDEBAR ===== */
        .sidebar {
            width: 250px;
            min-height: 100vh;
            background: #111;
            position: fixed;
            left: 0;
            top: 0;
            padding-top: 20px;
            transition: all 0.3s ease;
        }

            .sidebar.collapsed {
                width: 80px;
            }

            .sidebar a {
                color: #bbb;
                padding: 12px 20px;
                display: flex;
                align-items: center;
                gap: 10px;
                text-decoration: none;
                transition: 0.2s;
            }

                .sidebar a:hover, .sidebar .active {
                    background: #e50914;
                    color: white;
                }

            .sidebar i {
                font-size: 1.2rem;
            }

            .sidebar.collapsed span {
                display: none;
            }

        /* ===== MAIN ===== */
        .main {
            margin-left: 250px;
            padding: 20px;
            transition: all 0.3s;
        }

            .main.collapsed {
                margin-left: 80px;
            }

        /* ===== TOPBAR ===== */
        .topbar {
            background: white;
            padding: 12px 20px;
            border-bottom: 1px solid #ddd;
            margin-bottom: 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-radius: 10px;
        }

        .avatar {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            cursor: pointer;
        }

        .dropdown-menu {
            right: 0;
            left: auto;
        }
    </style>
</head>
<body>

    <!-- Toast -->
    @if (TempData["Success"] != null)
    {
        <div class="toast-container position-fixed bottom-0 end-0 p-3">
            <div class="toast show bg-success text-white">
                <div class="toast-body">
                    @TempData["Success"]
                </div>
            </div>
        </div>
    }

    <!-- SIDEBAR -->
    <div id="sidebar" class="sidebar">
        <h5 class="text-center text-white mb-4">🛠</h5>

        <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index"
           class="@(currentController == "Dashboard" ? "active" : "")">
            <i class="bi bi-speedometer2"></i> <span>Dashboard</span>
        </a>

        <a asp-area="Admin" asp-controller="Categories" asp-action="Index"
           class="@(currentController == "Categories" ? "active" : "")">
            <i class="bi bi-tags"></i> <span>Danh mục</span>
        </a>

        <a asp-area="Admin" asp-controller="Movies" asp-action="Index"
           class="@(currentController == "Movies" ? "active" : "")">
            <i class="bi bi-film"></i> <span>Bộ phim</span>
        </a>

        <a asp-area="Admin" asp-controller="Users" asp-action="Index"
           class="@(currentController == "Users" ? "active" : "")">
            <i class="bi bi-people"></i> <span>Tài khoản</span>
        </a>

        <hr class="text-secondary" />

        <a asp-controller="Home" asp-action="Index">
            <i class="bi bi-arrow-left"></i> <span>Trang chủ</span>
        </a>
    </div>

    <!-- MAIN -->
    <div id="main" class="main">

        <!-- TOPBAR -->
        <div class="topbar shadow-sm">

            <!-- Toggle -->
            <button class="btn btn-light btn-sm" onclick="toggleSidebar()">
                <i class="bi bi-list"></i>
            </button>

            <h6 class="mb-0">@ViewData["Title"]</h6>

            <!-- Avatar dropdown -->
            <div class="dropdown">
                <img src="https://i.pravatar.cc/40"
                     class="avatar dropdown-toggle"
                     data-bs-toggle="dropdown" />

                <ul class="dropdown-menu shadow">
                    <li>
                        <span class="dropdown-item-text">
                            👋 @User.Identity?.Name
                        </span>
                    </li>
                    <li><hr class="dropdown-divider"></li>

                    <li>
                        <a class="dropdown-item" href="/Account/Profile">
                            <i class="bi bi-person"></i> Thông tin
                        </a>
                    </li>

                    <li>
                        <a class="dropdown-item" href="/Account/ChangePassword">
                            <i class="bi bi-key"></i> Đổi mật khẩu
                        </a>
                    </li>

                    <li><hr class="dropdown-divider"></li>

                    <li>
                        <a class="dropdown-item text-danger" href="/Account/Logout">
                            <i class="bi bi-box-arrow-right"></i> Đăng xuất
                        </a>
                    </li>
                </ul>
            </div>

        </div>

        <!-- CONTENT -->
        @RenderBody()
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        // ===== SIDEBAR TOGGLE =====
        function toggleSidebar() {
            const sidebar = document.getElementById("sidebar");
            const main = document.getElementById("main");

            sidebar.classList.toggle("collapsed");
            main.classList.toggle("collapsed");

            localStorage.setItem("sidebar", sidebar.classList.contains("collapsed"));
        }

        // Load trạng thái
        window.onload = () => {
            if (localStorage.getItem("sidebar") === "true") {
                document.getElementById("sidebar").classList.add("collapsed");
                document.getElementById("main").classList.add("collapsed");
            }
        };

        // Auto hide toast
        setTimeout(() => {
            const toast = document.querySelector('.toast');
            if (toast) toast.classList.remove('show');
        }, 3000);
    </script>

    @RenderSection("Scripts", false)

</body>
</html>