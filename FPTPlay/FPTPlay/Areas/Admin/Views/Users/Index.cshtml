@model List<FPTPlay.Models.User>
@{
    ViewData["Title"] = "Quản lý Người dùng";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="card shadow-sm">
    <div class="card-header bg-dark text-white d-flex justify-content-between">
        <h5 class="mb-0">👥 Danh sách người dùng</h5>
        <a asp-action="Create" class="btn btn-light btn-sm">+ Thêm mới</a>
    </div>

    <div class="card-body">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>ID</th>
                    <th>Avatar</th>
                    <th>SĐT</th>
                    <th>Họ tên</th>
                    <th>Role</th>
                    <th>Trạng thái</th>
                    <th width="170">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var u in Model)
                {
                    <tr>
                        <td>@u.Id</td>

                        <td>
                            <img src="@(string.IsNullOrEmpty(u.AvatarUrl) ? "/images/avatar.png" : u.AvatarUrl)"
                                 width="40" class="rounded-circle" />
                        </td>

                        <td>@u.Mobile</td>
                        <td>@u.FullName</td>

                        <td>
                            <span class="badge bg-@(u.Role == "Admin" ? "danger" : "secondary")">
                                @u.Role
                            </span>
                        </td>

                        <td>
                            @if (u.IsActive)
                            {
                                <span class="badge bg-success">Hoạt động</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Khoá</span>
                            }
                        </td>

                        <td>
                            <a asp-action="Edit" asp-route-id="@u.Id"
                               class="btn btn-warning btn-sm">✏</a>

                            <a asp-action="Delete" asp-route-id="@u.Id"
                               class="btn btn-danger btn-sm"
                               onclick="return confirm('Bạn có chắc chắn muốn xóa user này?')">🗑</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>