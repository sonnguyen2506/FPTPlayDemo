@model FPTPlay.ViewModels.RegisterVM
@{
    ViewData["Title"] = "Đăng ký";
}

<div class="container d-flex justify-content-center align-items-center" style="min-height:90vh;">
    <div style="width:100%;max-width:420px;background:#1c1c1c;padding:30px;border-radius:16px;box-shadow:0 20px 60px rgba(0,0,0,.6);">

        <div class="text-center mb-4">
            <h4 style="color:#ff3b1f;">Đăng ký tài khoản</h4>
        </div>

        @if (ViewData.ModelState.ErrorCount > 0)
        {
            <div class="alert alert-danger">
                Vui lòng kiểm tra lại thông tin!
            </div>
        }

        <form asp-action="Register" method="post">

            <!-- Phone -->
            <div class="mb-3">
                <label class="form-label text-light">Số điện thoại</label>
                <input asp-for="Mobile" class="form-control bg-dark text-white border-0" placeholder="Nhập số điện thoại" />
                <span asp-validation-for="Mobile" class="text-danger"></span>
            </div>

            <!-- FullName -->
            <div class="mb-3">
                <label class="form-label text-light">Họ tên</label>
                <input asp-for="FullName" class="form-control bg-dark text-white border-0" placeholder="Nhập họ tên" />
                <span asp-validation-for="FullName" class="text-danger"></span>
            </div>

            <!-- Password -->
            <div class="mb-3 position-relative">
                <label class="form-label text-light">Mật khẩu</label>
                <input asp-for="Password" id="passwordInput" class="form-control bg-dark text-white border-0 pe-5" placeholder="Nhập mật khẩu" />
                <span asp-validation-for="Password" class="text-danger"></span>
                <i class="fas fa-eye position-absolute" style="right:15px;top:38px;cursor:pointer;color:#aaa;" onclick="togglePassword()"></i>
            </div>

            <!-- Confirm Password -->
            <div class="mb-3">
                <label class="form-label text-light">Xác nhận mật khẩu</label>
                <input asp-for="ConfirmPassword" class="form-control bg-dark text-white border-0" placeholder="Nhập lại mật khẩu" />
                <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-danger w-100 py-2 mt-2">
                Đăng ký
            </button>

            <div class="text-center mt-3">
                <a href="/Account/Login" class="text-warning">Đã có tài khoản? Đăng nhập</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        function togglePassword() {
            const input = document.getElementById("passwordInput");
            input.type = input.type === "password" ? "text" : "password";
        }
    </script>
}