@model FPTPlay.ViewModels.LoginVM
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

<!DOCTYPE html>
<html lang="vi">
<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<title>Đăng nhập</title>

	<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
	<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">

	<style>
		body {
			background: #000;
			color: #fff;
			font-family: sans-serif;
		}

		.login-overlay {
			position: fixed;
			inset: 0;
			background: rgba(0,0,0,0.75);
			backdrop-filter: blur(6px);
			display: flex;
			align-items: center;
			justify-content: center;
			z-index: 9999;
		}

		.login-box {
			background: #1c1c1c;
			padding: 30px;
			border-radius: 16px;
			width: 100%;
			max-width: 420px;
			box-shadow: 0 20px 60px rgba(0,0,0,0.8);
			position: relative;
		}

		.login-input {
			background: #111;
			border: 1px solid #333;
			color: #fff;
			border-radius: 30px;
			padding: 12px 16px;
		}

			.login-input:focus {
				border-color: #e50914;
				box-shadow: none;
			}

		.btn-close-custom {
			position: absolute;
			top: 10px;
			right: 12px;
			background: none;
			border: none;
			color: #aaa;
			font-size: 1.2rem;
		}

		.toggle-password {
			position: absolute;
			top: 50%;
			right: 15px;
			transform: translateY(-50%);
			cursor: pointer;
			color: #aaa;
		}

		.btn-danger {
			background: #ff3b1f;
			border: none;
			border-radius: 30px;
		}
	</style>
</head>

<body>

	<div class="login-overlay">
		<div class="login-box">

			<button class="btn-close-custom" onclick="history.back()">✕</button>

			<div class="text-center mb-4">
				<div style="color:#ff6a00;font-size:1.8rem;font-weight:600;">
					<i class="fas fa-play-circle"></i> FPT Play
				</div>
			</div>

			<h5 class="mb-3 fw-bold">Đăng nhập</h5>

			<!-- 🔥 FORM LOGIN -->
			<form asp-controller="Account" asp-action="Login" method="post">

				<!-- lỗi tổng -->
				<div asp-validation-summary="All" class="text-danger mb-2"></div>

				<!-- Phone -->
				<input asp-for="Mobile"
					   class="form-control login-input mb-3"
					   placeholder="Số điện thoại" />
				<span asp-validation-for="Mobile" class="text-danger small"></span>

				<!-- Password -->
				<div class="position-relative mb-3">
					<input asp-for="Password"
						   id="passwordInput"
						   class="form-control login-input pe-5"
						   placeholder="Mật khẩu" />
					<i class="fas fa-eye toggle-password" onclick="togglePassword()"></i>
				</div>
				<span asp-validation-for="Password" class="text-danger small"></span>

				<!-- Remember -->
				<div class="form-check mb-3">
					<input asp-for="RememberMe" class="form-check-input">
					<label class="form-check-label small">Ghi nhớ đăng nhập</label>
				</div>

				<button type="submit" class="btn btn-danger w-100 py-2 mb-3">
					Đăng nhập
				</button>

			</form>

			<div class="d-flex justify-content-between small">
				<a href="#" class="text-warning">Quên mật khẩu?</a>
				<a href="#" class="text-warning">Đăng ký</a>
			</div>

		</div>
	</div>

	<script>
		function togglePassword() {
			const input = document.getElementById("passwordInput");
			input.type = input.type === "password" ? "text" : "password";
		}
	</script>

	<!-- validation -->
	<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
	<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js"></script>
	<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/3.2.12/jquery.validate.unobtrusive.min.js"></script>

</body>
</html>