@model HomeViewModel
@using FPTPlay.ViewModels
@using System.Security.Claims

<!DOCTYPE html>
<html lang="vi">
<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<title>FPT Play - Trang chủ</title>

	<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
	<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">

	<style>
		:root {
			--primary-red: #e50914;
			--bg-dark: #000;
			--text-light: #e5e5e5
		}

		body {
			background: var(--bg-dark);
			color: var(--text-light);
			margin: 0;
			font-family: sans-serif;
			overflow-x: hidden
		}

		.navbar {
			background: rgba(0,0,0,.85);
			backdrop-filter: blur(12px);
			border-bottom: 1px solid rgba(255,255,255,.08)
		}

		.movie-grid {
			display: grid;
			grid-template-columns: repeat(auto-fill,minmax(140px,1fr));
			gap: 16px;
			padding: 0 8px
		}

		.movie-card {
			position: relative;
			border-radius: 8px;
			overflow: hidden;
			background: #111;
			aspect-ratio: 2/3;
			cursor: pointer;
			transition: .25s
		}

			.movie-card:hover {
				transform: scale(1.08);
				box-shadow: 0 20px 40px rgba(0,0,0,.6);
				z-index: 5
			}

			.movie-card img {
				width: 100%;
				height: 100%;
				object-fit: cover
			}

		.title-overlay {
			position: absolute;
			inset: 0;
			background: linear-gradient(to top,rgba(0,0,0,.92),transparent);
			display: flex;
			align-items: flex-end;
			padding: 10px;
			font-size: .9rem
		}

		.badge-ep {
			position: absolute;
			top: 8px;
			right: 8px;
			background: #e50914;
			color: #fff;
			font-size: .75rem;
			padding: 3px 8px;
			border-radius: 4px
		}

		.section-title {
			font-size: 1.4rem;
			margin: 32px 0 16px;
			padding-left: 8px
		}

		.qr-section {
			background: #0a0a0a;
			padding: 60px 20px;
			text-align: center;
			border-radius: 12px;
			margin: 60px auto;
			max-width: 500px
		}

		.avatar-img {
			width: 36px;
			height: 36px;
			border-radius: 50%;
			object-fit: cover;
			border: 2px solid #333;
			cursor: pointer
		}

			.avatar-img:hover {
				border-color: #e50914
			}
	</style>
</head>

<body>

	<!-- HEADER -->
	<nav class="navbar navbar-expand-lg fixed-top">
		<div class="container-fluid px-3 px-md-4">

			<a class="navbar-brand" href="/">
				<strong style="color:#e50914;font-size:1.6rem;">FPT Play</strong>
			</a>

			<!-- ✅ FIX RESPONSIVE -->
			<button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
				<span class="navbar-toggler-icon"></span>
			</button>

			<div class="collapse navbar-collapse" id="navbarNav">

				<ul class="navbar-nav me-auto">
					<li class="nav-item"><a class="nav-link active" href="#">Trang chủ</a></li>
					<li class="nav-item"><a class="nav-link" href="#">Phim bộ</a></li>
					<li class="nav-item"><a class="nav-link" href="#">Thiếu nhi</a></li>
				</ul>

				<div class="d-flex align-items-center gap-2">

					<input class="form-control bg-dark text-white border-0" placeholder="Tìm kiếm..." style="max-width:180px;">

					<i class="fas fa-bell text-white"></i>

					<a href="/Subscription" class="btn btn-danger btn-sm px-3">
						Mua gói
					</a>

					<!-- ✅ USER MENU -->
					@await Html.PartialAsync("_UserMenu")

				</div>
			</div>
		</div>
	</nav>

	<div style="height:70px;"></div>

	<!-- CONTENT -->
	<div class="container px-3 px-md-4">

		<h4 class="section-title">Mới ra mắt</h4>
		<div class="movie-grid">
			@foreach (var movie in Model.NewReleases)
			{
				<div class="movie-card">
					<img loading="lazy" src="@movie.PosterUrl" onerror="this.src='/images/default-poster.jpg'">
					<div class="title-overlay">@movie.Title</div>
					<span class="badge-ep">
						@(movie.VideoCount > 0 ? movie.VideoCount + " videos" : "Mới")
					</span>
				</div>
			}
		</div>

		<h4 class="section-title">Dành riêng cho bạn</h4>
		<div class="movie-grid">
			@foreach (var movie in Model.Personalized)
			{
				<div class="movie-card">
					<img loading="lazy" src="@movie.PosterUrl" onerror="this.src='/images/default-poster.jpg'">
					<div class="title-overlay">@movie.Title</div>
				</div>
			}
		</div>

		<div class="qr-section">
			<h5>Tải ứng dụng FPT Play</h5>
			<img loading="lazy" src="https://api.qrserver.com/v1/create-qr-code/?data=https://fptplay.vn/app&size=200x200">
		</div>

	</div>

	<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>