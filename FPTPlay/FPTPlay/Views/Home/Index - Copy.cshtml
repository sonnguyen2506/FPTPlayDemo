@model HomeViewModel
@using FPTPlay.ViewModels

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>FPT Play - Trang chủ</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" integrity="sha512-SnH5WK+bZxgPHs44uWIX+LLJAJ9/2PkPKZ5QiAj6Ta86w+fsb2TkcmfRyVX3pBnMFcV7oQPJkl9QevSCWr3W6A==" crossorigin="anonymous" referrerpolicy="no-referrer" />

    <style>
        :root {
            --primary-red: #e50914;
            --bg-dark: #000;
            --text-light: #e5e5e5;
        }

        body {
            background: var(--bg-dark);
            color: var(--text-light);
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
            margin: 0;
            overflow-x: hidden;
        }

        .navbar {
            background: rgba(0,0,0,0.85);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border-bottom: 1px solid rgba(255,255,255,0.08);
        }

        .movie-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
            gap: 16px;
            padding: 0 8px;
        }

        .movie-card {
            position: relative;
            border-radius: 8px;
            overflow: hidden;
            background: #111;
            aspect-ratio: 2 / 3;
            transition: transform 0.25s cubic-bezier(0.165, 0.84, 0.44, 1), box-shadow 0.25s ease;
            will-change: transform, box-shadow;
            cursor: pointer;
        }

            .movie-card:hover {
                transform: scale(1.08) translateZ(0);
                box-shadow: 0 20px 40px rgba(0,0,0,0.6);
                z-index: 5;
            }

            .movie-card img {
                width: 100%;
                height: 100%;
                object-fit: cover;
                display: block;
                image-rendering: -webkit-optimize-contrast;
            }

        .title-overlay {
            position: absolute;
            inset: 0 0 0 0;
            background: linear-gradient(to top, rgba(0,0,0,0.92) 0%, transparent 60%);
            display: flex;
            align-items: flex-end;
            padding: 12px 10px;
            font-size: 0.9rem;
            font-weight: 500;
            opacity: 0.95;
            pointer-events: none;
        }

        .badge-ep {
            position: absolute;
            top: 8px;
            right: 8px;
            background: var(--primary-red);
            color: white;
            font-size: 0.75rem;
            padding: 3px 8px;
            border-radius: 4px;
            font-weight: 600;
        }

        .section-title {
            font-size: 1.4rem;
            font-weight: 600;
            margin: 32px 0 16px;
            padding-left: 8px;
        }

        .qr-section {
            background: #0a0a0a;
            padding: 60px 20px;
            text-align: center;
            border-radius: 12px;
            margin: 60px auto;
            max-width: 500px;
        }

            .qr-section img {
                max-width: 180px;
                margin: 20px auto;
                display: block;
            }

        .movie-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)); /* tự động 2-3-4-5-6 cột tùy màn hình */
            gap: 16px;
            padding: 0 8px;
        }

        
        .movie-grid img {
            width: 100%;
            height: auto;
            aspect-ratio: 2 / 3; /* giữ tỷ lệ poster phim */
            object-fit: cover;
        }
    </style>
</head>
<body>

    <!-- Header -->
    <nav class="navbar navbar-expand-lg fixed-top">
        <div class="container-fluid px-3 px-md-4">
            <a class="navbar-brand" href="/">
                <strong style="color: #e50914; font-size: 1.6rem;">FPT Play</strong>
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item"><a class="nav-link active" href="#">Trang chủ</a></li>
                    <li class="nav-item"><a class="nav-link" href="#">Truyền hình</a></li>
                    <li class="nav-item"><a class="nav-link" href="#">Phim bộ</a></li>
                    <li class="nav-item"><a class="nav-link" href="#">Thiếu nhi</a></li>
                    <li class="nav-item"><a class="nav-link" href="#">Ngoại hạng Anh</a></li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">Xem thêm</a>
                        <ul class="dropdown-menu bg-dark border-0">
                            <li><a class="dropdown-item text-white" href="#">Phim lẻ</a></li>
                            <li><a class="dropdown-item text-white" href="#">Anime</a></li>
                        </ul>
                    </li>
                </ul>

                <div class="d-flex align-items-center gap-2">
                    <input class="form-control bg-dark text-white border-0" type="search" placeholder="Tìm kiếm..." style="max-width: 180px;" />

                    <i class="fas fa-bell fa-lg text-white"></i>

                    <!-- Nút mua gói -->
                    <a href="/Subscription" class="btn btn-danger btn-sm px-3">
                        Mua gói
                    </a>

                    <!-- Nút đăng nhập -->
                    <a href="/Account/Login" class="btn btn-outline-light btn-sm px-3" onclick="openLogin(); return false;">
                        Đăng nhập
                    </a>

                    <!-- Avatar (có thể ẩn khi chưa login sau này) -->
                    <i class="fas fa-user-circle fa-2x text-white"></i>
                </div>

            </div>
        </div>
    </nav>

    <div style="height: 70px;"></div>

    <!-- Banner quảng cáo -->
    <div class="alert alert-warning text-center mb-0 rounded-0 py-3 fw-bold" style="background: linear-gradient(90deg, #ffcc00, #ff9900); color: #000;">
        Quảng cáo • LPBank • Rực rỡ 18 • Đồng hành cùng Khán giả FPT Play • NHẬN ƯU ĐÃI NGAY
    </div>

    <div class="container px-3 px-md-4">
        <h4 class="section-title">Mới ra mắt</h4>
        <div class="movie-grid">
            @foreach (var movie in Model.NewReleases)
            {
                <div class="movie-card">
                    <img loading="lazy"
                         width="300" height="450"
                         src="@movie.PosterUrl"
                         alt="@movie.Title"
                         onerror="this.src='/images/default-poster.jpg'" />
                    <div class="title-overlay">@movie.Title</div>
                    @if (movie.VideoCount > 0)
                    {
                        <span class="badge-ep">@movie.VideoCount videos</span>
                    }
                    else
                    {
                        <span class="badge-ep">Mới</span>
                    }
                </div>
            }
        </div>

        <h4 class="section-title">Dành riêng cho bạn</h4>
        <div class="movie-grid">
            @foreach (var movie in Model.Personalized)
            {
                <div class="movie-card">
                    <img loading="lazy"
                         width="300" height="450"
                         src="@movie.PosterUrl"
                         alt="@movie.Title"
                         onerror="this.src='/images/default-poster.jpg'" />
                    <div class="title-overlay">@movie.Title</div>
                </div>
            }
        </div>

        <!-- QR section -->
        <div class="qr-section">
            <h5>Tải ứng dụng FPT Play trên thiết bị di động</h5>
            <p>Quét mã QR bên dưới</p>
            <img loading="lazy" src="https://api.qrserver.com/v1/create-qr-code/?data=https://fptplay.vn/app&size=200x200" alt="QR Code tải FPT Play" />
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
</body>
</html>